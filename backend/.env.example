# ─────────────────────────────────────────────────
# NEXUS — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# NVIDIA NIM API key (required for AI features)
# Get yours FREE at: https://build.nvidia.com/
# Click any model → "Get API Key" (top right)
NVIDIA_API_KEY=nvapi-your-key-here

# NVIDIA NIM model to use
# Options: meta/llama-3.1-70b-instruct | meta/llama-3.3-70b-instruct | mistralai/mistral-large-2-latest
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# NVIDIA NIM base URL (don't change this)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Database (SQLite for local dev)
DATABASE_URL=sqlite:///./nexus.db

# App settings
APP_ENV=development
APP_SECRET_KEY=change-me-in-production
FRONTEND_ORIGIN=http://localhost:3000

# ChromaDB vector store path
CHROMA_PERSIST_DIR=./chroma_data

# Org name shown in the UI
ORG_NAME=Acme Corp
